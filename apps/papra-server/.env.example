# Auth Configuration
AUTH_SECRET=your-secret-key-here-change-this-in-production
AUTH_IS_REGISTRATION_ENABLED=true
AUTH_IS_PASSWORD_RESET_ENABLED=true
AUTH_IS_EMAIL_VERIFICATION_REQUIRED=false

# Database
DATABASE_URL=file:./db.sqlite

# Server
PORT=1221
NODE_ENV=development

# Email (for development - use logger driver)
EMAILS_DRIVER=logger

# Tracking (disable for development)
TRACKING_DRIVER=none

# Static assets
STATIC_ASSETS_SERVE_CLIENT=true